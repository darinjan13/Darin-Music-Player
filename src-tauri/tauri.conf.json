{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Darin Music Player",
  "version": "0.1.0",
  "identifier": "com.darin.darinmusicplayer",
  "build": {
    "frontendDist": "../dist",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Darin Music Player",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "visible": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost; media-src 'self' asset: http://asset.localhost; connect-src 'self' asset: http://asset.localhost; script-src 'self'; style-src 'self' 'unsafe-inline';",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "bin/yt-dlp",
      "bin/ffmpeg"
    ],
    "resources": [
      "bin/*",
      "starter_assets/*"
    ],
    "icon": [
      "icons/app.ico",
      "icons/tray.png"
    ]
  }
}